# Copy to .env and fill in values — never commit .env to git

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=training.andyreagan.com localhost

# PostgreSQL
DB_NAME=training
DB_USER=training
DB_PASSWORD=change-me

# Path on the Synology NAS where Postgres data lives
# e.g. /volume1/docker/training/postgres
POSTGRES_DATA_PATH=/volume1/docker/training/postgres

# Cloudflare tunnel
TUNNEL_TOKEN=your-cloudflared-tunnel-token-here

# Strava OAuth (Phase 2 — leave blank to skip)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://training.andyreagan.com/integrations/strava/callback/
